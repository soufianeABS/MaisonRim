# SUPABASE CONFIGURATION

# ============================================

# Production app URL (no trailing slash). Required for correct confirmation / reset links in emails.
# Must match an entry under Redirect URLs in Supabase → Authentication → URL Configuration.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

NEXT_PUBLIC_SUPABASE_URL=https://zz.supabase.co

NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=zz.zzzz.zz-zzz

SUPABASE_SERVICE_ROLE_KEY=zz.zz.zz-1-zz



# ============================================

# CLOUDFLARE R2 (S3-compatible API)

# Dashboard: R2 → Manage R2 API Tokens. Account ID in URL or Overview.

# Optional: set R2_S3_API  to override endpoint (default: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)

# ============================================

R2_ACCOUNT_ID=zzz

R2_ACCESS_KEY_ID=zzz

R2_SECRET_ACCESS_KEY=zzz

R2_BUCKET_NAME=zzz

# ============================================
# Google Gemini (AI suggest reply)
# Get a key: https://aistudio.google.com/apikey
# Optional: GEMINI_MODEL=gemini-2.0-flash (default)
# ============================================

GEMINI_API_KEY=zzz

# ============================================
# IPTV / panel stealth proxy (optional)
# GET /api/iptv — Puppeteer + stealth; target URL must be set on the server.
# IPTV_STEALTH_SECRET — if set, require: Authorization: Bearer <same value>
# ============================================

# IPTV_STEALTH_TARGET_URL=https://example.com/api/api.php?action=new&type=m3u&sub=...
# IPTV_STEALTH_SECRET=long-random-string
# Local dev without env: GET /api/iptv?url=<url-encoded full https URL> (NODE_ENV=development only)

